#%PAM-1.0
# /etc/pam.d/meridian-login
#
# PAM stack for the meridian-login display manager.
#
# auth      — passwordless YubiKey/FIDO login. meridian-login resolves the
#             local user from /etc/Yubico/u2f_keys and passes the typed value
#             as the FIDO PIN to pam_u2f. No Unix account password is accepted
#             by this PAM service.
# account   — check account validity (not locked, not expired).
# session   — pam_systemd registers a logind session (class=user,
#             type=wayland) so the spawned compositor can acquire
#             the DRM card and input devices via libseat. pam_unix
#             handles utmp/wtmp bookkeeping and other per-user setup.
#
# meridian-login itself calls pam_open_session() after a successful
# pam_authenticate(), and keeps the PAM handle alive for the duration of the
# spawned compositor. On compositor exit the handle is dropped, which
# triggers pam_close_session and pam_end.
#
# Seat-binding (Phase 7c): auth.rs runs pam_set_item(PAM_TTY, "tty1")
# before pam_open_session so pam_systemd derives seat=seat0, vtnr=1 for
# the new logind session. Without that the seat would be empty and
# libseat-logind would refuse the compositor's DRM acquire.

auth      required   pam_u2f.so authfile=/etc/Yubico/u2f_keys origin=pam://meridian-login appid=pam://meridian-login cue pinverification=1 userverification=0
account   required   pam_unix.so
session   required   pam_systemd.so   class=user type=wayland
session   required   pam_unix.so
