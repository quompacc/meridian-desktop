#%PAM-1.0
# /etc/pam.d/meridian-login-password
#
# Password fallback stack for meridian-login.
# The primary meridian-login PAM service is reserved for pam_u2f smartcard
# auth. The UI selects this service only when no registered YubiKey is ready,
# so unplugging the key falls back to normal username/password login.

auth      required   pam_unix.so
account   required   pam_unix.so
session   required   pam_systemd.so   class=user type=wayland
session   required   pam_unix.so
